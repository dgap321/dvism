# ============================================================
# Production environment variables for DB BHISHM TABLET
# Copy to your server and fill in real values.
# These are loaded by deploy/redeploy.sh automatically.
# ============================================================

# Port the Express API server listens on (nginx proxies /api → this port)
API_PORT=8080

# Absolute path where all mutable data lives (OUTSIDE the git repo).
# This directory survives git pulls and redeploys.
# Contents: auth.db, changes.json, formations.json, user_dbs/
DATA_DIR=/var/data/bhishm

# Long random string for signing session cookies.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_RANDOM_SECRET

# Path where the git repo is checked out on the VPS
DEPLOY_PATH=/var/www/bhishm
