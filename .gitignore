# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# SQLite database files (runtime artifacts, not source)
*.db
*.db-shm
*.db-wal

# Seed/template DBs are tracked — they are source data, not runtime artifacts
!artifacts/api-server/src/bhishma.db
!artifacts/api-server/src/bhishma-original.db

# Runtime data files — live in DATA_DIR on production, excluded from git
artifacts/api-server/src/changes.json
artifacts/api-server/src/formations.json
artifacts/api-server/src/user_dbs/
artifacts/api-server/src/auth.db
artifacts/api-server/.env.runtime
