modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "gce"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-drive:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 8083
externalPort = 4200

[[ports]]
localPort = 8084
externalPort = 5000

[[ports]]
localPort = 8085
externalPort = 6800

[[ports]]
localPort = 25217
externalPort = 3000

[[ports]]
localPort = 25218
externalPort = 3001

[[ports]]
localPort = 25219
externalPort = 3002

[[ports]]
localPort = 25220
externalPort = 5173

[[ports]]
localPort = 25221
externalPort = 6000

[nix]
channel = "stable-25_05"
